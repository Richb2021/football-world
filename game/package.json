{
  "name": "football-world",
  "private": true,
  "version": "2.0.0",
  "description": "Football World — Manager, Player Career and Customisation football. Sequel to International Cup.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "deploy": "bash scripts/deploy-lftp.sh",
    "build:deploy": "npm run build && npm run deploy",
    "preview": "vite preview",
    "test": "vitest run",
    "commentary:dry-run": "node scripts/generate-elevenlabs-commentary.mjs --dry-run",
    "commentary:generate": "node scripts/generate-elevenlabs-commentary.mjs",
    "visuals:dry-run": "node scripts/generate-fal-visual-assets.mjs --dry-run",
    "visuals:generate": "node scripts/generate-fal-visual-assets.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "peerjs": "^1.5.4",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/functions": "^4.4.0",
    "@types/three": "^0.182.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.0.0"
  }
}
